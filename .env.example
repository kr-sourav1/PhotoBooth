# ---- Supabase (shared) ----
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key   # server / edge functions only — never ship to clients

# ---- Cloudflare R2 (preview object storage, S3-compatible) ----
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=photobooth-previews
R2_PUBLIC_BASE_URL=https://previews.yourcdn.com   # CDN domain in front of the bucket

# ---- Payment gateway (Stripe — optional, feature-flagged) ----
# Leave BILLING_ENABLED=false to run on the free plan with no gateway attached.
BILLING_ENABLED=false
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Vite apps (desktop + gallery; each app reads its own .env, must be VITE_-prefixed) ----
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_R2_PUBLIC_BASE_URL=https://previews.yourcdn.com
# Where the client gallery is hosted; the desktop app builds share links as <base>/g/<token>
VITE_GALLERY_BASE_URL=http://localhost:5173
