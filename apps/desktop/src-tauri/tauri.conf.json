{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PhotoBooth Studio",
  "version": "0.0.0",
  "identifier": "com.photobooth.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "PhotoBooth Studio",
        "width": 1100,
        "height": 740,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {}
}
